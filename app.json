{
  "name": "PGWIZ-MD",
  "description": " Whatsapp automation",
  "keywords": [
    "whatsapp Bot"
  ],
  "repository": "https://github.com/pgwiz/PGWIZ-MD",
  "stack": "container",
  "env": {
    "MONGO_URL": {
      "description": "Put if you have mongodb database url",
      "required": false,
      "value": ""
    },
    "MYSQL_URL": {
      "description": "Put if you have mysql database url",
      "required": false,
      "value": ""
    },
    "POSTGRES_URL": {
      "description": "Put if you have postgres database url",
      "required": false,
      "value": ""
    },
     "HKEY": {
      "description": "Put your Heroku api key Here , Get one from here https://dashboard.heroku.com/account",
      "required": true,
      "value": ""
    },
     "HAPP": {
      "description": "Put the Heroku app name, same as above entered",
      "required": true,
      "value": ""
    },
    "SESSION_ID": {
      "description": "Put your session id",
      "required": true,
      "value": ""
    },
    "DB_URL": {
      "description": "SQLite database file path",
      "required": false,
      "value": "./baileys_store.db"
    },
    "AUTO_STATUS_VIEW": {
      "description": "Automatically view all WhatsApp statuses",
      "required": false,
      "value": "true"
    },
    "AUTO_STATUS_REACT": {
      "description": "Automatically react to all WhatsApp statuses",
      "required": false,
      "value": "true"
    },
    "STATUS_EMOJIS": {
      "description": "Comma-separated emojis for status reactions",
      "required": false,
      "value": "💙,🖤,⭐"
    },
    "AUTOREAD": {
      "description": "Automatically mark incoming messages as read",
      "required": false,
      "value": "false"
    },
    "AUTOTYPING": {
      "description": "Automatically show typing indicator while processing",
      "required": false,
      "value": "false"
    },
    "ALWAYS_ONLINE": {
      "description": "Keep bot presence online continuously",
      "required": false,
      "value": "false"
    },
    "FORCE_SESSION_RESET": {
      "description": "Force full session reset at startup (one-time recovery toggle)",
      "required": false,
      "value": "true"
    },
     "REMOVEBG_KEY": {
      "description": "Put your Remove background api key",
      "required": false,
      "value": ""
    }
    },
    "buildpacks": [
    {
      "url": "heroku/nodejs"
    },
    {
      "url": "https://github.com/DuckyTeam/heroku-buildpack-imagemagick.git"
    },
    {
      "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest"
    },
    {
      "url": "https://github.com/clhuang/heroku-buildpack-webp-binaries.git"
    }
  ],
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  }
}
